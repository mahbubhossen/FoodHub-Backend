generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  address      String?   
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  role   Role       @default(CUSTOMER)
  status UserStatus @default(ACTIVE)
  phone  String?    @db.VarChar(20)

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  mealId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mealId])
  @@map("cart_items")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  meals Meal[]

  @@map("categories")
}

model Meal {
  id          String   @id @default(uuid())
  providerId  String
  categoryId  String
  name        String   @db.VarChar(150)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?  @db.VarChar(255)
  dietaryTags String?  @db.VarChar(100)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@index([providerId])
  @@index([categoryId])
  @@map("meals")
}

model Order {
  id              String      @id @default(uuid())
  customerId      String // better-auth (references User.id)
  providerId      String
  status          OrderStatus @default(PLACED)
  deliveryAddress String      @db.Text
  totalPrice      Decimal     @db.Decimal(10, 2)
  paymentMethod   String      @default("COD") @db.VarChar(50)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]
  reviews    Review[]

  @@index([customerId])
  @@index([providerId])
  @@map("orders")
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  mealId    String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  meal  Meal  @relation(fields: [mealId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([mealId])
  @@map("order_items")
}

model ProviderProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  restaurantName String   @db.VarChar(150)
  description    String?  @db.Text
  logoUrl        String?  @db.VarChar(255)
  address        String   @db.Text
  phone          String?  @db.VarChar(20)
  isOpen         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  meals  Meal[]
  orders Order[]

  @@index([userId])
  @@map("provider_profiles")
}

model Review {
  id         String   @id @default(uuid())
  customerId String // better-auth (references User.id)
  mealId     String
  orderId    String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  meal  Meal  @relation(fields: [mealId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([mealId])
  @@index([orderId])
  @@map("reviews")
}
